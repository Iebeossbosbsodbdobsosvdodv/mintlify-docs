{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Zynx Docs",
  "colors": {
    "primary": "#0D9488",
    "light": "#07C983",
    "dark": "#065F46"
  },
  "favicon": "/favicon.svg",
  "logo": "/logo/light.svg",
  "api": {
    "baseUrl": "https://api.zynxwallet.com.br",
    "auth": "key"
  },
  "openapi": "/openapi.json",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Começando",
            "pages": [
              "index",
              "about"
            ]
          }
        ]
      },
      {
        "tab": "Referência da API",
        "groups": [
          {
            "group": "Endpoints",
            "openapi": "openapi.json"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Suporte",
          "href": "https://t.me/zynxwallet_support",
          "icon": "headphones"
        },
        {
          "anchor": "Dashboard",
          "href": "https://dashboard.zynxwallet.com.br",
          "icon": "square-terminal"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Suporte",
        "href": "https://t.me/zynxwallet_support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.zynxwallet.com.br"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/zynxwallet",
      "github": "https://github.com/zynxwallet",
      "linkedin": "https://linkedin.com/company/zynxwallet"
    }
  }
}
