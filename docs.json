{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Zynx Wallet",
  "logo": "/logo/light.svg",
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#374151",
    "light": "#4B5563",
    "dark": "#1F2937"
  },
  "api": {
    "baseUrl": "https://api.zynxwallet.com.br",
    "auth": "key"
  },
  "openapi": "/openapi.json",
  "navigation": [
    {
      "group": "Documentação",
      "pages": ["index", "about"]
    },
    {
      "group": "Visão Geral",
      "pages": ["api-reference/overview", "api-reference/rate-limiting"]
    },
    {
      "group": "Pagamentos",
      "openapi": "openapi.json",
      "operations": ["post /v1/payments", "get /v1/payments/{id}", "get /v1/payments/list"]
    },
    {
      "group": "Saques",
      "openapi": "openapi.json",
      "operations": ["post /v1/withdrawals", "get /v1/withdrawals/{id}", "get /v1/withdrawals/list"]
    },
    {
      "group": "Transferências",
      "openapi": "openapi.json",
      "operations": ["post /v1/transfers", "get /v1/transfers/list"]
    },
    {
      "group": "Conta",
      "openapi": "openapi.json",
      "operations": ["get /v1/account/balance"]
    },
    {
      "group": "Webhooks",
      "openapi": "openapi.json",
      "operations": ["hook /webhooks"]
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "Página Principal",
        "href": "https://zynxwallet.com.br"
      },
      {
        "label": "Discord",
        "href": "https://discord.gg/zynxwallet"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://zynxwallet.com.br/dashboard"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/zynxwallet",
      "github": "https://github.com/zynxwallet",
      "linkedin": "https://linkedin.com/company/zynxwallet"
    }
  }
}
