{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Zynx Wallet",
  "logo": "/logo/light.svg",
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#374151",
    "light": "#4B5563",
    "dark": "#1F2937"
  },
  "api": {
    "baseUrl": "https://api.zynxwallet.com.br",
    "auth": "key"
  },
  "openapi": "/openapi.json",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Primeiros Passos",
            "pages": [
              "index",
              "about"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Referência",
            "openapi": "openapi.json"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "href": "https://discord.gg/zynxwallet",
          "icon": "message-circle"
        },
        {
          "anchor": "Dashboard",
          "href": "https://zynxwallet.com.br/dashboard",
          "icon": "square-terminal"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Página Principal",
        "href": "https://zynxwallet.com.br"
      },
      {
        "label": "Discord",
        "href": "https://discord.gg/zynxwallet"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://zynxwallet.com.br/dashboard"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/zynxwallet",
      "github": "https://github.com/zynxwallet",
      "linkedin": "https://linkedin.com/company/zynxwallet"
    }
  }
}
